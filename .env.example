PROJEQTOR_BASE_URL=https://mon-instance.projeqtor.com
# Auth: SOIT un bearer token, SOIT username + password (Basic). Au moins un requis.
# PROJEQTOR_BEARER_TOKEN=<jwt>      # prioritaire si défini
PROJEQTOR_USERNAME=api_user         # prenom.nom ou email de l'utilisateur Projeqtor
PROJEQTOR_PASSWORD=secret           # mot de passe de l'utilisateur Projeqtor
# Clé API AES — requise UNIQUEMENT pour les écritures (PUT/POST/DELETE).
PROJEQTOR_API_KEY=ma_cle_api_aes
PROJEQTOR_AES_KEY_LENGTH=128
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=3000
LOG_LEVEL=INFO
PROJEQTOR_TIMEOUT_SECONDS=30
PROJEQTOR_RETRY_ATTEMPTS=3
PROJEQTOR_RETRY_BASE_DELAY_SECONDS=0.3
