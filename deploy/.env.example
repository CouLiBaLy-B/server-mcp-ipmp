# --- Auth de l'endpoint MCP (agent -> gateway) ---
# Token que les agents doivent envoyer : Authorization: Bearer <GATE_TOKEN>
GATE_TOKEN=change-me-long-random-token

# --- Backend ProjeQtOr (serveur -> API) ---
PROJEQTOR_BASE_URL=https://mon-instance.projeqtor.com
# Auth ProjeQtOr : bearer OU (username + password). Bearer gagne si les deux sont présents.
PROJEQTOR_BEARER_TOKEN=
PROJEQTOR_USERNAME=
PROJEQTOR_PASSWORD=
# Requis seulement pour les écritures (PUT/POST/DELETE) chiffrées AES.
PROJEQTOR_API_KEY=
PROJEQTOR_AES_KEY_LENGTH=128

LOG_LEVEL=INFO
